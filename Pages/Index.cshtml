@page
@model UbimiaAspTest.Pages.IndexModel
@{
    ViewData["Title"] = "Calculadora";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ubimia</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f8f9fa; }
        .card { border: none; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
        .card-header { font-weight: 600; }
        .result-box {
            background: #e8f5e9;
            border-left: 4px solid #2e7d32;
            padding: 0.75rem 1rem;
            border-radius: 4px;
            font-size: 1.1rem;
        }
        .api-box {
            background: #f3f4f6;
            border-left: 4px solid #6c757d;
            padding: 0.75rem 1rem;
            border-radius: 4px;
            font-family: monospace;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark mb-4">
        <div class="container">
            <span class="navbar-brand fw-bold">Ubimia — Prueba Técnica</span>
        </div>
    </nav>

    <div class="container pb-5">
        <div class="row g-4">

            <!-- =============== FACTORIAL =============== -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-primary text-white">
                        Factorial
                    </div>
                    <div class="card-body">
                        <p class="text-muted small">Ingresá un número entero entre 0 y 20</p>

                        <form method="post" asp-page-handler="Factorial">
                            @Html.AntiForgeryToken()
                            <div class="input-group mb-3">
                                <input type="number" class="form-control" name="FactorialInput"
                                       value="@Model.FactorialInput" placeholder="Ej: 7" min="0" max="20" />
                                <button class="btn btn-primary" type="submit">Calcular</button>
                            </div>
                        </form>

                        @if (Model.FactorialError != null)
                        {
                            <div class="alert alert-danger py-2">@Model.FactorialError</div>
                        }

                        @if (Model.FactorialResult.HasValue)
                        {
                            <div class="result-box">
                                @Model.FactorialInput! = <strong>@Model.FactorialResult.Value.ToString("N0")</strong>
                            </div>
                        }

                        <hr />
                        <p class="text-muted small mb-1">También disponible vía API:</p>
                        <div class="api-box">GET /api/calculator/factorial/{n}</div>
                    </div>
                </div>
            </div>

            <!-- =============== ORDENAMIENTO =============== -->
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-header bg-success text-white">
                        Ordenamiento de 5 números
                    </div>
                    <div class="card-body">
                        <p class="text-muted small">Ingresá exactamente 5 números enteros separados por coma</p>

                        <form method="post" asp-page-handler="Sort">
                            @Html.AntiForgeryToken()
                            <div class="input-group mb-3">
                                <input type="text" class="form-control" name="SortInput"
                                       value="@Model.SortInput" placeholder="Ej: 42, 7, -3, 100, 15" />
                                <button class="btn btn-success" type="submit">Ordenar</button>
                            </div>
                        </form>

                        @if (Model.SortError != null)
                        {
                            <div class="alert alert-danger py-2">@Model.SortError</div>
                        }

                        @if (Model.SortResult != null && Model.SortOriginal != null)
                        {
                            <div class="result-box">
                                <div class="text-muted small mb-1">Original:</div>
                                <div>[@string.Join(", ", Model.SortOriginal)]</div>
                                <div class="text-muted small mt-2 mb-1">Ordenado:</div>
                                <div><strong>[@string.Join(", ", Model.SortResult)]</strong></div>
                            </div>
                        }

                        <hr />
                        <p class="text-muted small mb-1">También disponible vía API:</p>
                        <div class="api-box">
                            POST /api/calculator/sort<br />
                            Body: {"{ \"numbers\": [3,1,4,1,5] }"}
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
